{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Greffe",
  "version": "0.1.0",
  "identifier": "com.leomartin.greffe",
  "build": {
    "beforeDevCommand": "deno task dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "deno task build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Greffe — Réglages",
        "width": 740,
        "height": 640,
        "minWidth": 560,
        "minHeight": 480
      },
      {
        "label": "overlay",
        "url": "overlay.html",
        "title": "Greffe",
        "width": 116,
        "height": 40,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "focus": false,
        "shadow": false,
        "visible": false,
        "visibleOnAllWorkspaces": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
